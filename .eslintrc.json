{
  "root": true,
  "env": {
    "node": true,
    "jest": true
  },
  "plugins": ["security"],
  "extends": ["eslint:recommended", "plugin:security/recommended", "prettier"],
  "ignorePatterns": [],
  "overrides": [
    {
      "files": ["**/*.js"]
    }
  ],
  "rules": {
    "no-empty": [
      1,
      {
        "allowEmptyCatch": true
      }
    ]
  },
  "parserOptions": {
    "ecmaVersion": 2020
  }
}
